# Laravel (Hanya abaikan vendor, node_modules, log, cache, dan env sensitif)
/laravel/node_modules/
/laravel/vendor/
/laravel/.env
/laravel/.env.backup
/laravel/.env.production
/laravel/storage/logs/*.log
/laravel/storage/framework/cache/data/*
/laravel/storage/framework/sessions/*
/laravel/storage/framework/views/*
/laravel/storage/app/detections/*
!/laravel/storage/app/detections/.gitkeep
/laravel/database/*.sqlite
/laravel/database/*.sqlite-journal

# Python Edge (Hanya push file run produksi utama: orchestrator, camera_worker, inference_engine, config, rules, models, requirements)
/mlcv/venv/
/mlcv/__pycache__/
/mlcv/**/__pycache__/
/mlcv/.pytest_cache/
/mlcv/relay.log
/mlcv/test_inference.py
/mlcv/tests/

# Abaikan gambar simulasi & log hasil proses kamera di mlcv
/mlcv/cam1/processed/
/mlcv/cam2/processed/
/mlcv/cam3/processed/
/mlcv/*.ipynb

# Dokumentasi Internal Agen AI (Hanya file spesifik ini yang diabaikan di root)
/AGENTS.md
/SKILL.md
/research.google-design.md
/SIWAS_AI_Fullstack_Agent.md
/Sistem_Informasi_Pengawasan_Smart_City__SIWAS____GEMASTIK_2026.md

