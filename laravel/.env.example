APP_NAME=PESAT
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# MariaDB (production) — ganti sesuai kredensial VPS
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pesat
DB_USERNAME=pesat_user
DB_PASSWORD=

# Untuk UNIX socket (OpenLiteSpeed + MariaDB):
# DB_HOST=/var/run/mysqld/mysqld.sock
# DB_PORT=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Nonaktifkan Reverb hingga VPS >= 2GB
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# File cache — zero dependency, cocok untuk 1GB VPS
CACHE_STORE=file

# API key untuk autentikasi edge device — ganti dengan key unik
PESAT_API_KEY=your-api-key-here

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@pesat.lhokseumawe.go.id"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb — aktifkan hanya jika VPS >= 2GB
# BROADCAST_CONNECTION=reverb
# QUEUE_CONNECTION=database
# VITE_REVERB_APP_KEY=
# VITE_REVERB_HOST=
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https
